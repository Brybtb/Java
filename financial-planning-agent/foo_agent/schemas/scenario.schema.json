{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "What-if Scenario",
  "type": "object",
  "required": ["id", "label", "deltas"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "deltas": {
      "type": "array",
      "description": "Ordered list of edits applied to the base profile.",
      "items": {
        "type": "object",
        "required": ["path", "op", "value"],
        "properties": {
          "path": { "type": "string", "description": "dotted path into the profile" },
          "op": { "type": "string", "enum": ["set", "inc", "mul"] },
          "value": {}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
